{
  "todo-tree.general.tags": [
    "TODO",
    "IDEA",
    "CLARITY",
    "ALIGNMENT",
    "DISCUSS",
    "OPINION"
  ],
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
  "editor.codeActionsOnSave": {
    "source.fixAll.markdownlint": true,
  },
  "markdownlint.run": "onSave"
}